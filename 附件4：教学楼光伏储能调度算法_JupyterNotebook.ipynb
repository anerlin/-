   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "plt.rcParams['font.sans-serif'] = ['SimHei']\n",
    "plt.rcParams['axes.unicode_minus'] = False\n",
    "\n",
    "SOC_INIT = 50.0\n",
    "SOC_MAX = 80.0\n",
    "SOC_MIN = 20.0\n",
    "P_CHARGE_MAX = 10.0\n",
    "P_DISCHARGE_MAX = 10.0\n",
    "BAT_CAP = 100.0\n",
    "\n",
    "P_LINE_NORMAL = 60.0\n",
    "P_LINE_FAULT = 30.0\n",
    "FAULT_HOUR = [14, 15, 16]\n",
    "\n",
    "data = {\n",
    "    '时段(h)': list(range(24)),\n",
    "    '光伏出力(kW)': [0,0,0,0,0,0,0,15,30,45,50,50,45,35,25,15,5,0,0,0,0,0,0,0],\n",
    "    '教学楼负荷(kW)': [10,8,8,8,10,12,20,35,40,45,45,40,45,40,35,30,25,20,15,12,10,9,9,10],\n",
    "    '电价(元/kWh)': [0.4]*7 + [0.8]*14 + [0.4]*3\n",
    "}\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "df['正常_储能充放电(kW)'] = 0.0\n",
    "df['正常_电网购电(kW)'] = 0.0\n",
    "df['正常_SOC(%)'] = 0.0\n",
    "soc = SOC_INIT\n",
    "\n",
    "for i in range(24):\n",
    "    pv = df.loc[i, '光伏出力(kW)']\n",
    "    load = df.loc[i, '教学楼负荷(kW)']\n",
    "    price = df.loc[i, '电价(元/kWh)']\n",
    "    df.loc[i, '正常_SOC(%)'] = soc\n",
    "\n",
    "    charge_p = 0.0\n",
    "    discharge_p = 0.0\n",
    "    grid_p = 0.0\n",
    "\n",
    "    if pv > load:\n",
    "        surplus = pv - load\n",
    "        charge_p = min(surplus, P_CHARGE_MAX)\n",
    "        soc_incr = (charge_p * 1) / BAT_CAP * 100\n",
    "        if soc + soc_incr > SOC_MAX:\n",
    "            charge_p = (SOC_MAX - soc) * BAT_CAP / 100\n",
    "        soc += (charge_p * 1) / BAT_CAP * 100\n",
    "        grid_p = 0.0\n",
    "    elif pv < load:\n",
    "        deficit = load - pv\n",
    "        discharge_p = min(deficit, P_DISCHARGE_MAX)\n",
    "        soc_decr = (discharge_p * 1) / BAT_CAP * 100\n",
    "        if soc - soc_decr < SOC_MIN:\n",
    "            discharge_p = (soc - SOC_MIN) * BAT_CAP / 100\n",
    "        grid_p = deficit - discharge_p\n",
    "        soc -= (discharge_p * 1) / BAT_CAP * 100\n",
    "\n",
    "    if price == 0.4 and pv == 0 and soc < SOC_MAX:\n",
    "        opt_charge = min(P_CHARGE_MAX, (SOC_MAX - soc) * BAT_CAP / 100)\n",
    "        if opt_charge > 0:\n",
    "            charge_p = opt_charge\n",
    "            discharge_p = 0.0\n",
    "            grid_p = opt_charge\n",
    "            soc += (opt_charge * 1) / BAT_CAP * 100\n",
    "    elif price == 0.8 and pv < load and soc > SOC_MIN:\n",
    "        opt_discharge = min(deficit, P_DISCHARGE_MAX, (soc - SOC_MIN) * BAT_CAP / 100)\n",
    "        discharge_p = opt_discharge\n",
    "        grid_p = deficit - discharge_p\n",
    "        soc -= (opt_discharge * 1) / BAT_CAP * 100\n",
    "\n",
    "    df.loc[i, '正常_储能充放电(kW)'] = charge_p - discharge_p\n",
    "    df.loc[i, '正常_电网购电(kW)'] = max(grid_p, 0.0)\n",
    "\n",
    "df['故障_储能充放电(kW)'] = 0.0\n",
    "df['故障_电网购电(kW)'] = 0.0\n",
    "df['故障_SOC(%)'] = 0.0\n",
    "soc = SOC_INIT\n",
    "\n",
    "for i in range(24):\n",
    "    pv = df.loc[i, '光伏出力(kW)']\n",
    "    load = df.loc[i, '教学楼负荷(kW)']\n",
    "    price = df.loc[i, '电价(元/kWh)']\n",
    "    hour = df.loc[i, '时段(h)']\n",
    "    df.loc[i, '故障_SOC(%)'] = soc\n",
    "\n",
    "    charge_p = 0.0\n",
    "    discharge_p = 0.0\n",
    "    grid_p = 0.0\n",
    "\n",
    "    if pv > load:\n",
    "        surplus = pv - load\n",
    "        charge_p = min(surplus, P_CHARGE_MAX)\n",
    "        soc_incr = (charge_p * 1) / BAT_CAP * 100\n",
    "        if soc + soc_incr > SOC_MAX:\n",
    "            charge_p = (SOC_MAX - soc) * BAT_CAP / 100\n",
    "        soc += (charge_p * 1) / BAT_CAP * 100\n",
    "        grid_p = 0.0\n",
    "    elif pv < load:\n",
    "        deficit = load - pv\n",
    "        discharge_p = min(deficit, P_DISCHARGE_MAX)\n",
    "        soc_decr = (discharge_p * 1) / BAT_CAP * 100\n",
    "        if soc - soc_decr < SOC_MIN:\n",
    "            discharge_p = (soc - SOC_MIN) * BAT_CAP / 100\n",
    "        grid_p = deficit - discharge_p\n",
    "        soc -= (discharge_p * 1) / BAT_CAP * 100\n",
    "\n",
    "    if price == 0.4 and pv == 0 and soc < SOC_MAX:\n",
    "        opt_charge = min(P_CHARGE_MAX, (SOC_MAX - soc) * BAT_CAP / 100)\n",
    "        if opt_charge > 0:\n",
    "            charge_p = opt_charge\n",
    "            discharge_p = 0.0\n",
    "            grid_p = opt_charge\n",
    "            soc += (opt_charge * 1) / BAT_CAP * 100\n",
    "    elif price == 0.8 and pv < load and soc > SOC_MIN:\n",
    "        opt_discharge = min(deficit, P_DISCHARGE_MAX, (soc - SOC_MIN) * BAT_CAP / 100)\n",
    "        discharge_p = opt_discharge\n",
    "        grid_p = deficit - discharge_p\n",
    "        soc -= (opt_discharge * 1) / BAT_CAP * 100\n",
    "\n",
    "    if hour in FAULT_HOUR:\n",
    "        line_p = pv + max(discharge_p, 0.0)\n",
    "        if line_p > P_LINE_FAULT:\n",
    "            cut_discharge = line_p - P_LINE_FAULT\n",
    "            discharge_p = max(discharge_p - cut_discharge, 0.0)\n",
    "            grid_p += cut_discharge\n",
    "            soc += (cut_discharge * 1) / BAT_CAP * 100\n",
    "\n",
    "    df.loc[i, '故障_储能充放电(kW)'] = charge_p - discharge_p\n",
    "    df.loc[i, '故障_电网购电(kW)'] = max(grid_p, 0.0)\n",
    "\n",
    "def calc_metrics(df, version):\n",
    "    pv_total = df['光伏出力(kW)'].sum()\n",
    "    waste_pv = 0.0\n",
    "    for i in range(24):\n",
    "        pv = df.loc[i, '光伏出力(kW)']\n",
    "        load = df.loc[i, '教学楼负荷(kW)']\n",
    "        bat_p = df.loc[i, f'{version}_储能充放电(kW)']\n",
    "  
    " if hour in FAULT_HOUR:",
    " line_p = pv + max(discharge_p, 0.0)",
    " if line_p > P_LINE_FAULT:",
    "    cut_discharge = line_p - P_LINE_FAULT",
    "  if pv > P_LINE_FAULT:",
    "        pv_curtail = pv - P_LINE_FAULT",
    "        waste_pv += pv_curtail",
    "    absorb_rate = (pv_total - waste_pv) / pv_total * 100 if pv_total > 0 else 100.0\n",
    "    cost = (df[f'{version}_电网购电(kW)'] * df['电价(元/kWh)'] * 1).sum()\n",
    "    return round(absorb_rate, 2), round(cost, 2), 100.0\n",
    "\n",
    "normal_absorb, normal_cost, _ = calc_metrics(df, '正常')\n",
    "fault_absorb, fault_cost, _ = calc_metrics(df, '故障')\n",
    "\n",
    "print(\"正常工况：光伏消纳率 = {:.2f}%，日购电成本 = {:.2f}元\".format(normal_absorb, normal_cost))\n",
    "print(\"故障工况：光伏消纳率 = {:.2f}%，日购电成本 = {:.2f}元\".format(fault_absorb, fault_cost))\n",
    "\n",
    "# 可视化\n",
    "fig, ((ax1, ax2), (ax3, ax4)) = plt.subplots(2, 2, figsize=(12, 8))\n",
    "x = df['时段(h)']\n",
    "\n",
    "ax1.plot(x, df['光伏出力(kW)'], label='光伏出力(kW)')\n",
    "ax1.plot(x, df['教学楼负荷(kW)'], label='教学楼负荷(kW)')\n",
    "ax1.axvspan(14, 16, color='red', alpha=0.1, label='故障时段')\n",
    "ax1.set_title('24小时光伏出力与教学楼负荷')\n",
    "ax1.legend()\n",
    "ax1.grid(True)\n",
    "\n",
    "ax2.plot(x, df['正常_电网购电(kW)'], label='正常工况')\n",
    "ax2.plot(x, df['故障_电网购电(kW)'], label='故障工况')\n",
    "ax2.axvspan(14, 16, color='red', alpha=0.1)\n",
    "ax2.set_title('电网购电功率对比')\n",
    "ax2.legend()\n",
    "ax2.grid(True)\n",
    "\n",
    "ax3.plot(x, df['正常_SOC(%)'], label='正常工况SOC')\n",
    "ax3.plot(x, df['故障_SOC(%)'], label='故障工况SOC')\n",
    "ax3.axhline(y=SOC_MAX, color='r', linestyle='--', label='SOC上限')\n",
    "ax3.axhline(y=SOC_MIN, color='r', linestyle='--', label='SOC下限')\n",
    "ax3.axvspan(14, 16, color='red', alpha=0.1)\n",
    "ax3.set_title('储能SOC变化')\n",
    "ax3.legend()\n",
    "ax3.grid(True)\n",
    "\n",
    "ax4.plot(x, df['正常_储能充放电(kW)'], label='正常工况')\n",
    "ax4.plot(x, df['故障_储能充放电(kW)'], label='故障工况')\n",
    "ax4.axhline(y=0, color='black', linestyle='-', alpha=0.5)\n",
    "ax4.axvspan(14, 16, color='red', alpha=0.1)\n",
    "ax4.text(2, 8, '正数=充电', color='green')\n",
    "ax4.text(2, -8, '负数=放电', color='red')\n",
    "ax4.set_title('储能充放电功率')\n",
    "ax4.legend()\n",
    "ax4.grid(True)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "df.to_excel('教学楼光伏储能_24小时调度结果.xlsx', index=False)"
   ]
  },
